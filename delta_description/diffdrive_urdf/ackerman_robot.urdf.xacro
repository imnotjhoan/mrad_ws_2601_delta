<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ackerman_robot">

  <!-- ================= PROPIEDADES ================= -->
  <xacro:property name="lx_box" value="${41/100}"/>
  <xacro:property name="ly_box" value="${16/100}"/>
  <xacro:property name="lz_box" value="${13.3/100}"/>

  <xacro:property name="off_x" value="${12.55/100}"/>
  <xacro:property name="off_y" value="${12.15/100}"/>
  <xacro:property name="off_z" value="${5.45/100}"/>
  <xacro:property name="off_z_chasi" value="${6.65/100}"/>

  <xacro:property name="rad_cil" value="${10.2/2/100}"/>
  <xacro:property name="altura" value="${4.5/100}"/>
  <!-- ================= MACROS ================= -->

  <!-- Ruedas -->
  <xacro:macro name="wheel_macro" params="w_name w_radius w_length">
    <link name="${w_name}">
      <visual>
        <geometry>
          <cylinder radius="${w_radius}" length="${w_length}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      </visual>

      <collision>
        <geometry>
          <cylinder radius="${w_radius}" length="${w_length}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      </collision>

      <inertial>
        <mass value="1.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.01" ixy="0" ixz="0"
                 iyy="0.01" iyz="0"
                 izz="0.01"/>
      </inertial>
    </link>
  </xacro:macro>

  <!-- Steering links (dirección) -->
  <xacro:macro name="steering_macro" params="name">
    <link name="${name}">
      <visual>
        <geometry>
          <cylinder radius="0.02" length="0.05"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </visual>

      <collision>
        <geometry>
          <cylinder radius="0.02" length="0.05"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </collision>

      <inertial>
        <mass value="0.2"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.0001" ixy="0" ixz="0"
                 iyy="0.0001" iyz="0"
                 izz="0.0001"/>
      </inertial>
    </link>
  </xacro:macro>

  <!-- ================= LINKS BASE ================= -->

  <link name="base_link"/>

  <link name="chassis_link">
    <visual>
      <geometry>
        <box size="${lx_box} ${ly_box} ${lz_box}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>

    <collision>
      <geometry>
        <box size="${lx_box} ${ly_box} ${lz_box}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>

    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.2" ixy="0" ixz="0"
               iyy="0.2" iyz="0"
               izz="0.2"/>
    </inertial>
  </link>

  <!-- ================= JOINT BASE ================= -->

  <joint name="base_chassis_joint" type="fixed">
    <parent link="base_link"/>
    <child link="chassis_link"/>
    <origin xyz="0 0 ${off_z_chasi}" rpy="0 0 0"/>
  </joint>

  <!-- ================= STEERING LINKS ================= -->

  <xacro:steering_macro name="steering_FR_link"/>
  <xacro:steering_macro name="steering_FL_link"/>

  <!-- ================= JOINTS ================= -->

  <!-- Ruedas traseras -->
  <joint name="chassis_wheel_RR_joint" type="continuous">
    <parent link="chassis_link"/>
    <child link="rwheel_link"/>
    <origin xyz="-${off_x} -${off_y} -${off_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="chassis_wheel_RL_joint" type="continuous">
    <parent link="chassis_link"/>
    <child link="rwheel_link2"/>
    <origin xyz="-${off_x} ${off_y} -${off_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Dirección -->
  <joint name="chassis_rotate_FR_joint" type="continuous">
    <parent link="chassis_link"/>
    <child link="steering_FR_link"/>
    <origin xyz="${off_x} -${off_y} -${off_z}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="chassis_rotate_FL_joint" type="continuous">
    <parent link="chassis_link"/>
    <child link="steering_FL_link"/>
    <origin xyz="${off_x} ${off_y} -${off_z}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Ruedas delanteras -->
  <joint name="chassis_wheel_FR_joint" type="continuous">
    <parent link="steering_FR_link"/>
    <child link="rwheel_link3"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="chassis_wheel_FL_joint" type="continuous">
    <parent link="steering_FL_link"/>
    <child link="rwheel_link4"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ================= RUEDAS ================= -->

  <xacro:wheel_macro w_name="rwheel_link"  w_radius="${rad_cil}" w_length="${altura}"/>
  <xacro:wheel_macro w_name="rwheel_link2" w_radius="${rad_cil}" w_length="${altura}"/>
  <xacro:wheel_macro w_name="rwheel_link3" w_radius="${rad_cil}" w_length="${altura}"/>
  <xacro:wheel_macro w_name="rwheel_link4" w_radius="${rad_cil}" w_length="${altura}"/>

</robot>
